{
  "name": "smart-press-appium-tests",
  "version": "1.0.0",
  "description": "Appium E2E Automation tests for Smart Press Flutter App with Excel Reporting",
  "main": "index.js",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "appium:install": "appium driver install uiautomator2",
    "appium:run": "appium --address 127.0.0.1 --port 4723",
    "build:apk": "cd ../smart_press && flutter build apk --debug"
  },
  "dependencies": {
    "appium": "^2.11.3",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@wdio/appium-service": "^9.28.0",
    "@wdio/cli": "^8.40.6",
    "@wdio/local-runner": "^8.40.6",
    "@wdio/mocha-framework": "^8.40.2",
    "@wdio/spec-reporter": "^8.39.0",
    "appium-uiautomator2-driver": "^2.45.1"
  }
}
